{
  "schema": 1,
  "rules": [
    {
      "name": "caused-by",
      "pattern": "Caused by:",
      "priority": 30,
      "cls": "h-caused-by"
    },
    {
      "name": "stack-frame",
      "pattern": "\\bat\\s+(?<fqn>[A-Za-z_$][\\w$.]*)\\(((?<file>[^:()\\s]+):(?<line>\\d+)|Native Method|Unknown Source)\\)",
      "priority": 40,
      "cls": "h-stack-frame",
      "subgroups": {
        "fqn": { "cls": "h-stack-fqn" },
        "file": { "cls": "h-stack-file" },
        "line": { "cls": "h-stack-line" }
      }
    },
    {
      "name": "java-exception",
      "pattern": "\\b[A-Z][A-Za-z0-9_]*(?:Exception|Error)\\b",
      "priority": 20,
      "cls": "h-exception"
    },
    {
      "name": "url",
      "pattern": "\\bhttps?://[A-Za-z0-9._~:/?#@!$&'()*+,;=%\\-]+",
      "priority": 50,
      "cls": "h-url",
      "url": "self"
    },
    {
      "name": "ipv4",
      "pattern": "\\b(?:(?:25[0-5]|2[0-4]\\d|[01]?\\d\\d?)\\.){3}(?:25[0-5]|2[0-4]\\d|[01]?\\d\\d?)\\b",
      "priority": 15,
      "cls": "h-ip"
    },
    {
      "name": "ipv6",
      "pattern": "(?:(?:[A-Fa-f0-9]{1,4}:){7}[A-Fa-f0-9]{1,4}|[A-Fa-f0-9]{1,4}:(?::[A-Fa-f0-9]{1,4}){1,6}|(?:[A-Fa-f0-9]{1,4}:){1,2}(?::[A-Fa-f0-9]{1,4}){1,5}|(?:[A-Fa-f0-9]{1,4}:){1,3}(?::[A-Fa-f0-9]{1,4}){1,4}|(?:[A-Fa-f0-9]{1,4}:){1,4}(?::[A-Fa-f0-9]{1,4}){1,3}|(?:[A-Fa-f0-9]{1,4}:){1,5}(?::[A-Fa-f0-9]{1,4}){1,2}|(?:[A-Fa-f0-9]{1,4}:){1,6}:[A-Fa-f0-9]{1,4}|::(?:[A-Fa-f0-9]{1,4}:){0,6}[A-Fa-f0-9]{1,4}|(?:[A-Fa-f0-9]{1,4}:){1,7}:|::)",
      "priority": 15,
      "cls": "h-ip"
    },
    {
      "name": "path-windows",
      "pattern": "(?<path>[A-Za-z]:\\\\[A-Za-z0-9_.\\\\\\-]+)",
      "priority": 10,
      "subgroups": { "path": { "cls": "h-path" } }
    },
    {
      "name": "path-unix",
      "pattern": "(?:(?<=\\s)|(?<=^)|(?<=[=:'\"\\(]))(?<path>/[A-Za-z0-9_.\\-]+(?:/[A-Za-z0-9_.\\-]+)+)",
      "priority": 10,
      "subgroups": { "path": { "cls": "h-path" } }
    }
  ]
}
