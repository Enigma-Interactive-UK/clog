{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Clog",
  "version": "1.0.0",
  "identifier": "dev.clog.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Clog",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "lewster32",
    "copyright": "Copyright (c) 2026 lewster32",
    "category": "DeveloperTool",
    "shortDescription": "Viewer for log4j2-formatted Play 1.x logs",
    "longDescription": "Clog (Core Log) is a Windows desktop application for viewing, tailing, searching and filtering log4j2-formatted log files produced by Play 1.x Java applications.",
    "homepage": "https://github.com/lewster32/clog",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["log", "out"],
        "name": "Clog Log File",
        "description": "Log file viewable in Clog",
        "role": "Viewer"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser",
        "languages": ["English"],
        "displayLanguageSelector": false,
        "installerIcon": "icons/icon.ico"
      }
    }
  }
}
